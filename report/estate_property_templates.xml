<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_property_offers_table">
        <table class="table mt32">
            <thead>
                <tr>
                    <th>Prezzo</th>
                    <th>Partner</th>
                    <th>Stato</th>
                </tr>
            </thead>
            <tbody>
                <tr t-foreach="offers" t-as="offer">
                    <td><span t-field="offer.price"/></td>
                    <td><span t-field="offer.partner_id"/></td>
                    <td><span t-field="offer.status"/></td>
                </tr>
            </tbody>
        </table>
    </template>

    <template id="report_property_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="property">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2><span t-field="property.name"/></h2>
                        <div>
                            <strong>Prezzo richiesto: </strong>
                            <span t-field="property.expected_price"/>
                        </div>

                        <t t-if="property.offer_ids">
                            <t t-set="offers" t-value="property.offer_ids"/>
                            <t t-call="estate.report_property_offers_table"/>
                        </t>
                        <t t-else="">
                            <p>Non ci sono ancora offerte per questa proprietà.</p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_user_properties">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="user">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h1>Venditore: <span t-field="user.name"/></h1>
                        
                        <t t-if="user.property_ids">
                            <t t-foreach="user.property_ids" t-as="property">
                                <div class="mt32">
                                    <h2>Proprietà: <span t-field="property.name"/></h2>
                                    
                                    <t t-if="property.offer_ids">
                                        <t t-set="my_offers" t-value="property.offer_ids"/>
                                        
                                        <t t-if="my_offers">
                                            <t t-call="estate.report_property_offers_table">
                                                <t t-set="offers" t-value="my_offers"/>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <p class="text-muted">Nessuna offerta gestita da te per questa proprietà.</p>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <p>Questa proprietà non ha ancora ricevuto offerte.</p>
                                    </t>
                                </div>
                            </t>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>